<!DOCTYPE html>
<html>
  <head>
    <title>Foodlog</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <% if notice.present? %>
    <div id="notification is-link is-light"><%= notice %></div>
  <% end %>

  <% if notice.present? %>
    <div id="notification is-danger is-light"><%= alert %></div>
  <% end %>

  <div class="container">
    <%= yield %>
  </div>

  </body>
</html>
